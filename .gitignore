# Xcode
build/
dist/
DerivedData/
.derivedData/

# dSYMs are 50 MB binaries kept per release for crash symbolication. Too heavy
# for git history — `scripts/release` uploads them to the version's GitHub
# release instead, so the local folder is just a staging area.
dSYMs/
*.xcuserstate
*.xcuserdata
xcuserdata/

# Swift Package Manager
.build/
.swiftpm/xcode/package.xcworkspace/xcuserdata/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Icon preview renders
Productivity/Flowlog.icon/.previews/

# Local env / secrets
.env
.env.*

# Sparkle signing key export (private — keep in Keychain or 1Password)
sparkle/eddsa_private.key

# Downloaded Sparkle CLI tools
build/sparkle-tools/

# Local Sparkle release archives (appcast.xml is committed)
updates/releases/
updates/old_updates/
